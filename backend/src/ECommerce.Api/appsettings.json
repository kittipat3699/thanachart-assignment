{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Supabase": {
    "Url": "https://your-project-id.supabase.co",
    "DbConnectionString": "Host=db.your-project-id.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=your-password;SSL Mode=Require;Trust Server Certificate=true",
    "AnonKey": "your-anon-key",
    "ServiceRoleKey": "your-service-role-key",
    "JwtAudience": "authenticated"
  }
}
